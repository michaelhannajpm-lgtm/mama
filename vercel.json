    {
      "source": "/admin",
      "destination": "/"
    },
    {
      "source": "/admin/:path*",
      "destination": "/"
    },
    {
      "source": "/builder",
      "destination": "/"
    },
    {
      "source": "/builder/:path*",
      "destination": "/"
    },
    {
      "source": "/live",
      "destination": "/"
    },
    {
