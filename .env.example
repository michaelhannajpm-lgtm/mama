# Builder (Claude on gomama.app)
BUILDER_ALLOWED_EMAILS=you@example.com,analyst@example.com
BUILDER_WEBHOOK_SECRET=<64-hex-chars>
GITHUB_TOKEN_BUILDER=<fine-grained PAT>
GITHUB_REPO=michaelhannajpm-lgtm/mama
# Optional: ref to dispatch the workflow from (defaults to master).
# Use while the workflow file is still on a feature branch.
# BUILDER_WORKFLOW_REF=feat/builder-on-gomama
VERCEL_API_TOKEN=<read-only token>
VERCEL_PROJECT_ID=<from .vercel/project.json>
